# === Azure AI Foundry / Azure OpenAI (Criterion 3) ===
# Your Foundry/OpenAI resource endpoint, WITHOUT a path.
#   e.g. https://my-foundry-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# The model *deployment* name you created in Microsoft Foundry (not the base model id).
#   e.g. gpt-4o, gpt-4.1, gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Optional: a separate (often cheaper/stronger) deployment used by the eval judge.
# Falls back to AZURE_OPENAI_DEPLOYMENT if empty.
AZURE_OPENAI_JUDGE_DEPLOYMENT=

# Auth — choose ONE:
#   A) Keyless Microsoft Entra ID (RECOMMENDED): leave AZURE_OPENAI_API_KEY blank and run `az login`.
#   B) API key (simplest for a hackathon): paste the key below.
AZURE_OPENAI_API_KEY=
